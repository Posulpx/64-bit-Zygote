{
  "name": "default",
  "version": 1,
  "genes": [
    {
      "cell_type": "sensor",
      "version": 1,
      "asm_path": "cells/sensor.bin",
      "stack_size": 512,
      "state_size": 256,
      "timeout_us": 100,
      "spawn_condition": {
        "on_startup": true,
        "probability": 1.0
      },
      "max_instances": 5,
      "signal_affinity": [1],
      "mutation_rate": 0.01,
      "metadata": {
        "description": "Reads external signals, increments counter, forwards"
      }
    },
    {
      "cell_type": "logger",
      "version": 1,
      "asm_path": "cells/logger.bin",
      "stack_size": 512,
      "state_size": 256,
      "timeout_us": 100,
      "spawn_condition": {
        "on_startup": true,
        "probability": 1.0
      },
      "max_instances": 3,
      "signal_affinity": [1],
      "mutation_rate": 0.01,
      "metadata": {
        "description": "Logs signal type_id and payload to state buffer"
      }
    }
  ]
}
